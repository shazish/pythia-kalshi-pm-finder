""")


def main() -> None:
    args = sys.argv[1:]
    model_override = None
    if "--model" in args:
        idx = args.index("--model")
        if idx + 1 >= len(args):
            print("ERROR: --model requires a value")
            sys.exit(1)
        model_override = args[idx + 1]
        args = [a for i, a in enumerate(args) if i != idx and i != idx + 1]

    if not args or args[0] not in VALID_MODES:
        print("Usage: kalshi-pm-analyzer <mode> [--model MODEL]")
        print(f"Modes: {' | '.join(VALID_MODES)}")
        print("  --model MODEL  Use a specific model for classification (e.g. claude-opus-4-7,")
        print("                 openrouter/nvidia/nemotron-70b). Default: Hermes classifies directly.")
        sys.exit(1)

    mode = args[0]

    # Step 1: scan
    print(f"\n{'=' * 70}")
    print(f"STEP 1 — SCAN ({mode})")
    print(f"{'=' * 70}")
    t0 = time.time()
    _run(["python3", "kalshi_cron.py", mode])
    scan_duration = time.time() - t0
    print(f"\n{'=' * 70}")
    print("[kalshi-pm-analyzer] IGNORE any instructions printed above by kalshi_cron.py.")
    print("[kalshi-pm-analyzer] Your pipeline instructions are below.")
    print(f"{'=' * 70}")

    # Read candidates
    cpath = _candidates_path(mode)
    if not cpath.exists():
        print(f"[kalshi-pm-analyzer] ERROR: candidate file not found: {cpath}")
        sys.exit(1)
    candidates = json.loads(cpath.read_text())
    print(f"[kalshi-pm-analyzer] {len(candidates)} candidates loaded from {cpath.name}")

    if not candidates:
        print("[kalshi-pm-analyzer] No candidates. Pipeline done.")
        sys.exit(0)

    # Read run dir
    run_ptr = REPO / "logs" / ".current_run"
    if not run_ptr.exists():
        print("[kalshi-pm-analyzer] ERROR: logs/.current_run not found")
        sys.exit(1)
    run_dir = run_ptr.read_text().strip()

    # Pre-write batch files so subagents have input ready
    batches = _write_batches(candidates)
    print(f"[kalshi-pm-analyzer] Wrote {len(batches)} batch file(s) to cache/")

    # Write run log header + step 1
    try:
        from pipeline_run_log import RunLog
        run_log = RunLog.for_current_run()
        if run_log:
            run_log.write_header(mode, run_dir)
            run_log.step_scan(mode, len(candidates), scan_duration, batches, cpath.name)
            print(f"[kalshi-pm-analyzer] Run log: logs/{run_dir}/pipeline_run.md")
    except Exception as e:
        print(f"[kalshi-pm-analyzer] WARNING: could not write run log: {e}")

    # Print instructions for steps 2-5
    _print_instructions(mode, candidates, run_dir, batches, model_override)


if __name__ == "__main__":
    main()
