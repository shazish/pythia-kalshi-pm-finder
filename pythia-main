# ── Main ──────────────────────────────────────────────────────────────────────

def main() -> None:
    _print_banner()
    args = sys.argv[1:]

    if args and args[0] == "finalize":
        finalize()
        return

    if args and args[0] == "backtest":
        from backtest import run as backtest_run
        backtest_run()
        return

    model_override = None
    if "--model" in args:
        idx = args.index("--model")
        if idx + 1 >= len(args):
            print("ERROR: --model requires a value")
            sys.exit(1)
        model_override = args[idx + 1]
        args = [a for i, a in enumerate(args) if i != idx and i != idx + 1]

    if not args or args[0] not in VALID_MODES:
        print("Usage: kalshi-pm-analyzer <mode> [--model MODEL]")
        print("       kalshi-pm-analyzer finalize")
        print("       kalshi-pm-analyzer backtest")
        print(f"Modes: {' | '.join(VALID_MODES)}")
        print("  --model MODEL  Use a specific model for classification (e.g. openrouter/owl-alpha).")
        print("                 Default: Hermes classifies in-context, no external API key needed.")
        sys.exit(1)

    mode = args[0]

    # Step 1: scan
    print(f"\n{'=' * 70}")
    print(f"STEP 1 — SCAN ({mode})")
    print(f"{'=' * 70}")
    t0 = time.time()

    run_path, run_dir = _init_run(mode)

    print(f"[kalshi-pm-analyzer] Running {mode} scan...")
    try:
        if mode == "anomaly":
            candidates = run_anomaly_scan()
        elif mode.startswith("pm-"):
            candidates = run_pm_scan(mode)
        else:
            candidates = run_price_scan(mode)
        cand_file = str(_candidates_path(mode))
    except Exception as e:
        import traceback
        msg = f"Scan failed ({mode}): {e}\n{traceback.format_exc()}"
        print(f"[kalshi-pm-analyzer] ERROR: {msg}", file=sys.stderr)
        try:
            from pipeline_run_log import RunLog
            log = RunLog.for_current_run()
            if log:
                log.step_error(f"Step 1 — Scan ({mode})", msg)
        except Exception:
            pass
        sys.exit(1)

    scan_duration = time.time() - t0
    print(f"[kalshi-pm-analyzer] Scanner found {len(candidates)} candidates")

    if not candidates:
        print("[kalshi-pm-analyzer] No candidates. Pipeline done.")
        sys.exit(0)

    _copy_to_run(cand_file, run_path)

    # Pre-write batch files so subagents have input ready (not needed for anomaly — scorer, not research)
    if "anomaly" not in mode:
        batches = _write_batches(candidates)
        print(f"[kalshi-pm-analyzer] Wrote {len(batches)} batch file(s) to logs/{run_dir}/")
    else:
        batches = []

    # Write run log header + step 1
    try:
        from pipeline_run_log import RunLog
        run_log = RunLog.for_current_run()
        if run_log:
            run_log.write_header(mode, run_dir)
            run_log.step_scan(mode, len(candidates), scan_duration, batches, Path(cand_file).name)
            print(f"[kalshi-pm-analyzer] Run log: logs/{run_dir}/pipeline_run.md")
    except Exception as e:
        print(f"[kalshi-pm-analyzer] WARNING: could not write run log: {e}")

    # Print instructions for steps 2-5
    _print_instructions(mode, candidates, run_dir, batches, model_override)


if __name__ == "__main__":
    main()
