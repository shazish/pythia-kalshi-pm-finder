# ── Archive ───────────────────────────────────────────────────────────────────

def _archive_run(excel_path, run_path, run_dir, cache_dir: Path = None):
    if cache_dir is None:
        cache_dir = _run_cache()
    # When KALSHI_CACHE_DIR == run_path, artifacts are already there — skip copy
    already_in_run = os.path.realpath(str(cache_dir)) == os.path.realpath(run_path)
    copied = 0
    if not already_in_run:
        for name in _RUN_ARTIFACTS:
            src = str(cache_dir / name)
            if os.path.exists(src):
                dst = os.path.join(run_path, name)
                if not os.path.exists(dst) or os.path.getmtime(src) > os.path.getmtime(dst):
                    shutil.copy2(src, dst)
                    copied += 1
        for pattern in _RUN_ARTIFACT_GLOBS:
            for src in sorted(glob.glob(str(cache_dir / pattern))):
                dst = os.path.join(run_path, os.path.basename(src))
                if not os.path.exists(dst) or os.path.getmtime(src) > os.path.getmtime(dst):
                    shutil.copy2(src, dst)
                    copied += 1
    excel_basename = os.path.basename(excel_path)
    excel_in_run = os.path.join(run_path, excel_basename)
    if excel_path != excel_in_run and os.path.exists(excel_path):
        shutil.move(excel_path, excel_in_run)
    if already_in_run:
        print(f"[kalshi-pm-analyzer] Archived run → logs/{run_dir}/  (artifacts already in run folder + Excel)")
    else:
        print(f"[kalshi-pm-analyzer] Archived run → logs/{run_dir}/  ({copied} cache artifacts + Excel)")
    return run_dir


# ── Finalize ──────────────────────────────────────────────────────────────────

def finalize():
    from pipeline_logger import get_logger
    from classifier import validate_classification
    log = get_logger("kalshi-pm-analyzer")

    # Snapshot cache dir now — _init_run() (called below as fallback) may change KALSHI_CACHE_DIR
    _cache_dir = _run_cache()
    classified_path = str(_cache_dir / "classified.json")
    if not os.path.exists(classified_path):
        log.error("No classified.json found at %s. Classification step must run first.", classified_path)
        print("[kalshi-pm-analyzer] No classified.json found. Classification step must run first.")
        sys.exit(1)

    try:
        with open(classified_path) as f:
            classified = json.load(f)
    except json.JSONDecodeError as e:
        print(f"[kalshi-pm-analyzer] classified.json is malformed — cannot finalize: {e}")
        sys.exit(1)

    log.info("finalize() started — %d entries loaded from classified.json", len(classified))

    _SCAN_TYPE_MAP = {
        "deep_scan":           "deep",
        "deep_spread_scan":    "deep",
        "full_scan":           "full",
        "incremental_scan":    "incremental",
        "anomaly_scan":        "anomaly",
        "pm_deep_scan":        "pm-deep",
        "pm_full_scan":        "pm-full",
        "pm_incremental_scan": "pm-incremental",
        "pm_anomaly_scan":     "pm-anomaly",
        "backtest":            "backtest",
    }
    _scan_types = [
        cm.get("candidate", {}).get("scan_type", "")
        for cm in classified
        if isinstance(cm.get("candidate"), dict)
    ]
    _non_empty = [st for st in _scan_types if st]
    if _non_empty:
        from collections import Counter
        _most_common = Counter(_non_empty).most_common(1)[0][0]
    else:
        _most_common = ""
    mode_label = _SCAN_TYPE_MAP.get(_most_common, "finalize")

    _type_order = {k: i for i, k in enumerate(reversed(list(_SCAN_TYPE_MAP.keys())))}
    classified.sort(key=lambda cm: _type_order.get(
        cm.get("candidate", {}).get("scan_type", ""), 999
    ))

    total_classified = len(classified)
    for i, cm in enumerate(classified):
        _print_progress("Classification - Verify", i + 1, total_classified)
        if "candidate" not in cm:
            log.warning("Entry %d has no 'candidate' key — will produce blank report columns", i)
        elif not isinstance(cm.get("candidate"), dict):
            log.warning("Entry %d 'candidate' is %s, not dict", i, type(cm["candidate"]).__name__)
        elif not cm.get("candidate", {}).get("series_ticker"):
            log.debug("Entry %d (%s) missing series_ticker", i,
                      cm.get("candidate", {}).get("ticker", "?"))

    for cm in classified:
        if "classification" in cm and isinstance(cm["classification"], dict):
            candidate_obj = cm.get("candidate", {})
            cm["classification"] = validate_classification(
                cm["classification"],
                rules=candidate_obj.get("rules_primary", ""),
                candidate=candidate_obj,
            )

    from opportunity_manager import OpportunityManager
    from excel_reporter import export_excel

    try:
        mgr = OpportunityManager()
        to_notify, to_log = mgr.process(classified)
    except Exception as e:
        log.error("OpportunityManager failed: %s", e)
        print(f"[kalshi-pm-analyzer] ERROR: opportunity manager failed: {e}", file=sys.stderr)
        try:
            from pipeline_run_log import RunLog
            rl = RunLog.for_current_run()
            if rl:
                rl.step_error("Step 5 — Finalize (OpportunityManager)", str(e))
        except Exception:
            pass
        raise

    if to_log:
        n = mgr.log_to_dashboard(to_log)
        log.info("Logged %d entries to dashboard", n)
        print(f"[kalshi-pm-analyzer] Logged {n} entries to dashboard")

    if to_notify:
        log.info("Reporting %d opportunities", len(to_notify))
        print(f"\n[kalshi-pm-analyzer] {len(to_notify)} OPPORTUNITIES:")
        for opp in to_notify:
            print("\n" + mgr.format_notification(opp))
    else:
        log.info("No opportunities above threshold")
        print("[kalshi-pm-analyzer] No opportunities above threshold.")

    run_path, run_dir = _get_current_run()
    if run_path is None:
        run_path, run_dir = _init_run(mode_label)
        log.warning("No .current_run pointer found; created fallback run folder: logs/%s/", run_dir)

    excel_basename = f"{run_dir}.xlsx"
    excel_path = os.path.join(LOGS_DIR, excel_basename)
    try:
        result_path = export_excel(to_notify, to_log, excel_path, mode_label=mode_label)
    except Exception as e:
        log.error("Excel export failed: %s", e)
        print(f"[kalshi-pm-analyzer] ERROR: Excel export failed: {e}", file=sys.stderr)
        try:
            from pipeline_run_log import RunLog
            rl = RunLog.for_current_run()
            if rl:
                rl.step_error("Step 5 — Finalize (Excel export)", str(e))
        except Exception:
            pass
        raise

    _archive_run(result_path, run_path, run_dir, cache_dir=_cache_dir)

    try:
        from pipeline_run_log import RunLog
        run_log = RunLog.for_current_run()
        if run_log:
            routing_summary = {
                "Opportunities notified": len(to_notify),
                "Logged to dashboard":   len(to_log),
            }
            run_log.step_finalize(
                n_entries=len(classified),
                report_path=f"logs/{run_dir}/{excel_basename}",
                routing_summary=routing_summary,
                errors=[],
            )
    except Exception as _rle:
        log.warning("Could not write run log step 5: %s", _rle)

    try:
        os.remove(CURRENT_RUN_POINTER)
    except OSError:
        pass

    log.info("Report saved → logs/%s/", run_dir)
    print(f"\n[kalshi-pm-analyzer] Run complete → logs/{run_dir}/")


# ── Batch writing ─────────────────────────────────────────────────────────────

def _candidates_path(mode: str) -> Path:
    return _run_cache() / _CANDIDATES_MAP.get(mode, "candidates.json")


def _n_batches(n: int) -> int:
    return max(2, math.ceil(n / 15))


def _write_batches(candidates: list) -> list:
    """Write raw candidate slices to the run cache dir as research_batch{N}.json. Returns [(index, count, path)]."""
    n_batches = _n_batches(len(candidates))
    batch_size = math.ceil(len(candidates) / n_batches)
    written = []
    for i in range(n_batches):
        start = i * batch_size
        end = min(start + batch_size, len(candidates))
        batch = candidates[start:end]
        if not batch:
            continue
        path = _run_cache() / f"research_batch{i}.json"
        path.write_text(json.dumps(batch, indent=2))
        written.append((i, len(batch), path))
    return written


